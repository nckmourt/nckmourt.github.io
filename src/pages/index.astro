---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import SocialLinks from "../components/SocialLinks.astro";
import HomepageFeaturedProjects from "../components/HomepageFeaturedProjects.astro";
import HomepageMoreWorkGrid from "../components/HomepageMoreWorkGrid.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const allProjects = [...projects].sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const heroCapableProjects = allProjects.filter((project) => project.data.heroImage);
const featuredProjectSlugs = [
  "how-senators-voted-on-trump-s-cabinet-picks",
  "the-major-supreme-court-decisions-in-2025",
  "why-are-democrats-fleeing-texas-to-block-redistric",
  "trump-s-first-100-days-in-10-charts",
  "low-cost-steps-we-can-take-to-stop-the-surge-in-pe",
];
const featuredProjects = featuredProjectSlugs
  .map((slug) => heroCapableProjects.find((project) => project.slug === slug))
  .filter(Boolean);
const featuredSlugs = new Set(featuredProjects.map((project) => project.slug));
const voteCountProjects = heroCapableProjects.filter((project) => {
  const tags = project.data.tags || [];
  return tags.includes("votes") && !tags.includes("explainers") && !featuredSlugs.has(project.slug);
});
const houseVoteProjects = voteCountProjects.filter((project) => {
  const title = (project.data.title || "").toLowerCase();
  return title.includes("house");
});
const senateVoteProjects = voteCountProjects.filter((project) => {
  const title = (project.data.title || "").toLowerCase();
  return title.includes("senate") || title.includes("senator") || !title.includes("house");
});
const voteCountSlugs = new Set(voteCountProjects.map((project) => project.slug));
const moreWorkProjects = heroCapableProjects
  .filter((project) => !featuredSlugs.has(project.slug) && !voteCountSlugs.has(project.slug))
  .slice(0, 25);

const photos = [
  { id: 1, src: "/photos/35070831673_975b40802c_b.jpg", alt: "Photo 1" },
  { id: 2, src: "/photos/36027750031_59b4987814_b.jpg", alt: "Photo 2" },
  { id: 3, src: "/photos/35329166424_6d523e6654_b.jpg", alt: "Photo 3" },
  { id: 4, src: "/photos/36124029652_e50bf0d900_b.jpg", alt: "Photo 4" },
  { id: 5, src: "/photos/36158808351_a40b42edb6_b.jpg", alt: "Photo 5" },
  { id: 6, src: "/photos/35897171070_24b34964e3_b.jpg", alt: "Photo 6" },
  { id: 7, src: "/photos/36317102492_6a9371f00f_b.jpg", alt: "Photo 7" },
  { id: 8, src: "/photos/36348085541_ec239636ea_b.jpg", alt: "Photo 8" },
  { id: 9, src: "/photos/41071355214_f38170d93c_b.jpg", alt: "Photo 9" },
  { id: 10, src: "/photos/39981195220_b9e3e3332a_b.jpg", alt: "Photo 10" },
  { id: 11, src: "/photos/45987968891_9538f7560e_b.jpg", alt: "Photo 11" },
];
---
<BaseLayout title="Nick Mourtoupalas | Graphics and data visualization" description="Professional portfolio of graphics journalism, data visualization, and photography.">
  <section id="home">
    <Hero />
  </section>

  <section id="graphics" class="section section-divided featured-section">
    <div class="section-heading-shell">
      <div class="section-heading">
        <h2 class="section-title">Featured Work</h2>
      </div>
    </div>
    <HomepageFeaturedProjects projects={featuredProjects} />
  </section>

  <section id="vote-counts" class="section section-divided vote-counts-section">
    <div class="section-heading-shell">
      <div class="section-heading">
        <h2 class="section-title">Vote Counts</h2>
        <p class="section-description vote-counts-description">
          These stories track how Congress votes on pivotal legislation, holding each chamber and individual lawmaker accountable with clear, direct vote breakdowns published in real time or shortly after the action happens.
        </p>
      </div>
    </div>
    <div class="vote-counts-columns">
      <div class="vote-counts-column">
        <div class="vote-counts-subheading-shell">
          <div class="vote-counts-subheading">
            <h3 class="vote-counts-subtitle">House</h3>
          </div>
        </div>
        <HomepageMoreWorkGrid projects={houseVoteProjects} compact={true} groupedToggle="vote-counts" />
      </div>
      <div class="vote-counts-column">
        <div class="vote-counts-subheading-shell">
          <div class="vote-counts-subheading">
            <h3 class="vote-counts-subtitle">Senate</h3>
          </div>
        </div>
        <HomepageMoreWorkGrid projects={senateVoteProjects} compact={true} groupedToggle="vote-counts" />
      </div>
    </div>
    <div class="graphics-grid-actions vote-counts-actions">
      <button class="graphics-show-more site-action-button" type="button" data-more-work-group-toggle="vote-counts" hidden>
        Show More
      </button>
    </div>
  </section>

  <section id="more-work" class="section section-divided more-work-section">
    <div class="section-heading-shell">
      <div class="section-heading">
        <h2 class="section-title">More Work</h2>
      </div>
    </div>
    <HomepageMoreWorkGrid projects={moreWorkProjects} />
  </section>

  <section id="photos" class="section section-divided">
    <div class="section-heading-shell">
      <div class="section-heading">
        <h2 class="section-title">Photography</h2>
      </div>
    </div>
    <PhotoGallery photos={photos} />
  </section>

  <section id="about-contact" class="section section-divided about-section">
    <div class="section-heading-shell">
      <div class="section-heading">
        <h2 class="section-title about-title">About & Contact</h2>
      </div>
    </div>
    <div class="container about-wrap">
      <div class="about-grid">
        <div class="about-copy">
          <div class="about-photo-inline-frame">
            <img
              class="about-photo"
              src="/images/headshot.jpg"
              alt="Nick Mourtoupalas headshot"
              loading="lazy"
            />
          </div>
          <p>
            Nick Mourtoupalas is a data visualization journalist based in Washington, D.C., and a native of the D.C. metropolitan area.
          </p>
          <p>
            With a background in economics and data analytics, he reports on political power, public policy and economic systems, translating complex institutional data into structured visual coverage. His work spans congressional votes, federal spending, elections, courts and markets, building live trackers, recurring databases and durable tools used during breaking news and long-running coverage. He combines reporting judgment, quantitative analysis, cartography and front-end development to make government systems understandable and measurable.
          </p>
          <p>
            In addition to his reporting, Nick shoots film photography, documenting cities, landscapes and everyday life with the same attention to structure and composition that informs his journalism. Outside of work, he enjoys seeing live music, exploring Washington, running, traveling and spending time with the people closest to him.
          </p>
        </div>
        <div class="about-side">
          <div class="about-photo-frame">
            <img
              class="about-photo"
              src="/images/headshot.jpg"
              alt="Nick Mourtoupalas headshot"
              loading="lazy"
            />
          </div>
          <div class="about-actions">
            <SocialLinks className="about-social" iconSet="themeAware" />
            <a class="resume-link site-action-button" href="/resume.pdf" target="_blank" rel="noopener noreferrer">View Resume</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

<script>
  const groupedMoreWorkButtons = document.querySelectorAll("[data-more-work-group-toggle]");

  groupedMoreWorkButtons.forEach((button) => {
    const group = button.dataset.moreWorkGroupToggle;
    const roots = Array.from(document.querySelectorAll(`[data-more-work-group="${group}"]`));

    if (!roots.length) {
      button.hidden = true;
      return;
    }

    const syncButton = () => {
      const needsToggle = roots.some((root) => root.dataset.moreWorkNeedsToggle === "true");
      const isExpanded = roots.some((root) => root.dataset.moreWorkExpanded === "true");

      button.hidden = !needsToggle;
      button.textContent = isExpanded ? "Show Less" : "Show More";
    };

    roots.forEach((root) => {
      root.addEventListener("more-work:state-change", syncButton);
    });

    button.addEventListener("click", () => {
      const shouldExpand = !roots.some((root) => root.dataset.moreWorkExpanded === "true");
      roots.forEach((root) => {
        root.dispatchEvent(
          new CustomEvent("more-work:set-expanded", {
            detail: { expanded: shouldExpand },
          }),
        );
      });

      if (!shouldExpand) {
        const firstRoot = roots[0];
        firstRoot?.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    });

    syncButton();
  });
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: var(--surface-0);
    color: var(--text);
  }

  .section {
    padding: 0 0 80px;
    background: var(--surface-0);
    color: var(--text);
  }

  .section-divided {
    padding-top: 28px;
  }

  .featured-section {
    padding-bottom: 92px;
  }

  .more-work-section {
    padding-bottom: 88px;
  }

  .vote-counts-section {
    padding-bottom: 88px;
  }

  .vote-counts-actions {
    width: min(1180px, calc(100% - 44px));
    margin-left: auto;
    margin-right: auto;
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .vote-counts-columns {
    width: min(1180px, calc(100% - 44px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
    align-items: start;
  }

  .vote-counts-column {
    min-width: 0;
  }

  .vote-counts-subheading-shell {
    width: 100%;
    margin: 0 0 20px;
  }

  .vote-counts-subheading {
    width: 100%;
    padding-bottom: 18px;
  }

  .vote-counts-subtitle {
    margin: 0;
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: clamp(2rem, 3.2vw, 2.8rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-heading);
    line-height: 0.95;
    text-align: center;
  }

  .section-heading-shell {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .section-heading {
    width: 100%;
    margin: 0;
    padding-top: clamp(24px, 4.6vw, 44px);
    padding-bottom: clamp(22px, 3vw, 30px);
  }

  .section-heading::after {
    content: "";
    display: block;
    width: 100%;
    margin: clamp(18px, 2.5vw, 24px) auto 0;
    border-top: 1px solid var(--border-subtle);
  }

  .section-title {
    margin: 0 auto;
    width: min(100%, 860px);
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: clamp(2.7rem, 6vw, 4.5rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-heading);
    line-height: 0.95;
    text-align: center;
  }

  .section-description {
    width: min(100%, 500px);
    margin: 18px auto 0;
    font-family: "Inter", sans-serif;
    font-size: clamp(1rem, 1.15vw, 1.14rem);
    line-height: 1.55;
    color: var(--text-muted);
    text-align: center;
  }

  .vote-counts-description {
    width: min(75%, 885px);
    max-width: none;
    font-size: 16px;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 640px) {
    .vote-counts-columns {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  .section-kicker {
    width: min(100%, 860px);
    margin: 0 auto;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-align: center;
  }

  .about-section {
    padding-bottom: 70px;
  }

  .about-wrap {
    max-width: 1200px;
  }

  .about-title {
    margin-bottom: 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) 240px;
    align-items: start;
    gap: 44px;
    max-width: 860px;
    margin: 0 auto;
    justify-content: space-between;
  }

  .about-copy {
    font-family: "Inter", sans-serif;
    color: var(--text);
    font-size: 16px;
    line-height: 1.6;
    max-width: none;
    width: 100%;
    justify-self: start;
  }

  .about-copy p {
    margin: 0 0 26px;
    max-width: none;
  }

  .about-photo-inline-frame {
    display: none !important;
  }

  :global(.about-social) {
    --social-size: 26px;
    --social-bg: rgba(var(--theme-accent-rgb), 0.12);
    --social-border: rgba(var(--theme-accent-rgb), 0.45);
    --social-color: var(--text-heading);
    --social-hover-bg: rgba(var(--theme-accent-rgb), 0.2);
    --social-hover-border: rgba(var(--theme-accent-rgb), 0.8);
    --social-hover-color: var(--text-heading);
  }

  .about-side {
    width: 240px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-self: end;
  }

  .about-actions {
    --about-action-gap: 8px;
    margin-top: 30px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: var(--about-action-gap);
    width: 100%;
    flex-wrap: nowrap;
    align-self: stretch;
    overflow: hidden;
  }

  .resume-link {
    flex: 0 0 auto;
    width: max-content;
  }

  .about-actions :global(.about-social) {
    margin-left: 0;
    gap: var(--about-action-gap);
  }

  .about-photo-frame {
    display: block !important;
    width: 240px;
    max-width: 240px;
    border: 6px solid var(--border-strong);
    background: var(--surface-3);
    padding: 0;
  }

  .about-photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .section {
      padding-bottom: 64px;
    }
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: minmax(0, 1fr);
      justify-content: stretch;
    }

    .about-side {
      display: none !important;
    }

    .about-photo-inline-frame {
      float: right;
      display: block !important;
      width: 160px;
      height: 160px;
      border: 6px solid var(--border-strong);
      background: var(--surface-3);
      margin: 0 0 12px 14px;
    }

  }

  @media (max-width: 700px) {
    .section-title,
    .about-title {
      font-size: 3.5rem;
    }
  }

  @media (max-width: 600px) {
    .about-photo-inline-frame {
      width: 120px;
      height: 120px;
      margin-left: 10px;
    }

    .about-actions {
      gap: 12px;
    }
  }
</style>
