---
const { projects = [], compact = false, groupedToggle = "", showToggle = true } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

function formatDisplayDate(dateText) {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateText ?? "");
  if (!match) return dateText;

  const [, yearText, monthText, dayText] = match;
  const parsed = new Date(Number(yearText), Number(monthText) - 1, Number(dayText));
  return Number.isNaN(parsed.getTime()) ? dateText : dateFormatter.format(parsed);
}
---
<div
  class:list={["homepage-more-work-wrap", compact && "is-compact"]}
  data-more-work-wrap
  data-more-work-group={groupedToggle || undefined}
>
  <section class="homepage-more-work-shell is-collapsed" data-more-work-shell>
    <div class="homepage-more-work-fade" aria-hidden="true"></div>
    <div class="homepage-more-work" data-more-work-grid>
      {projects.map((project) => {
        const href = project.data.externalUrl || `/projects/${project.slug}/`;
        const target = project.data.externalUrl ? "_blank" : "_self";

        return (
          <a
            class="homepage-more-work-card"
            href={href}
            target={target}
            rel={project.data.externalUrl ? "noopener noreferrer" : ""}
            aria-label={project.data.title}
          >
            <article class="homepage-more-work-card-inner">
              <div class="homepage-more-work-media">
                {project.data.heroImage ? (
                  <img
                    class="homepage-more-work-image"
                    src={project.data.heroImage}
                    alt={project.data.title}
                    loading="lazy"
                  />
                ) : (
                  <div class="homepage-more-work-placeholder">{project.data.title}</div>
                )}
              </div>
              <div class="homepage-more-work-copy">
                <div class="homepage-more-work-title-wrap">
                  <h3 class="homepage-more-work-title">{project.data.title}</h3>
                </div>
                <p class="homepage-more-work-date">{formatDisplayDate(project.data.date)}</p>
              </div>
            </article>
          </a>
        );
      })}
    </div>
  </section>
  {showToggle && !groupedToggle && (
    <div class="graphics-grid-actions">
      <button class="graphics-show-more site-action-button" type="button" data-more-work-show-more hidden>Show More</button>
    </div>
  )}
</div>

<script>
  const roots = document.querySelectorAll("[data-more-work-wrap]");

  roots.forEach((root) => {
    const shell = root.querySelector("[data-more-work-shell]");
    const grid = root.querySelector("[data-more-work-grid]");
    const cards = Array.from(root.querySelectorAll(".homepage-more-work-card"));
    const images = Array.from(root.querySelectorAll(".homepage-more-work-image"));
    const button = root.querySelector("[data-more-work-show-more]");
    const collapsedRows = 3;
    const isVoteCountsGroup = root.dataset.moreWorkGroup === "vote-counts";
    const peekFraction = isVoteCountsGroup ? 0.3 : 0.52;
    let isExpanded = false;
    let updateFrame = 0;

    const scheduleUpdate = () => {
      if (updateFrame) window.cancelAnimationFrame(updateFrame);
      updateFrame = window.requestAnimationFrame(() => {
        updateFrame = window.requestAnimationFrame(() => {
          updateCollapsedState();
        });
      });
    };

    const updateCollapsedState = () => {
      if (!shell || !grid) return;

      const computedStyles = window.getComputedStyle(grid);
      const templateColumns = computedStyles.gridTemplateColumns
        .split(" ")
        .filter((value) => value.trim().length > 0);
      const columnCount = Math.max(1, templateColumns.length);
      const defaultVisibleCount = columnCount * collapsedRows;
      const needsToggle = cards.length > defaultVisibleCount;

      root.dataset.moreWorkNeedsToggle = String(needsToggle);
      root.dataset.moreWorkExpanded = String(isExpanded);

      if (!needsToggle) {
        shell.style.maxHeight = "";
        shell.classList.remove("is-collapsed", "is-expanded");
        if (button) button.hidden = true;
        root.dispatchEvent(
          new CustomEvent("more-work:state-change", {
            detail: { expanded: false, needsToggle: false },
          }),
        );
        return;
      }

      if (button) {
        button.hidden = false;
        button.textContent = isExpanded ? "Show Less" : "Show More";
      }
      shell.classList.toggle("is-collapsed", !isExpanded);
      shell.classList.toggle("is-expanded", isExpanded);
      root.dataset.moreWorkExpanded = String(isExpanded);
      root.dispatchEvent(
        new CustomEvent("more-work:state-change", {
          detail: { expanded: isExpanded, needsToggle: true },
        }),
      );

      if (isExpanded) {
        shell.style.maxHeight = `${grid.scrollHeight}px`;
        return;
      }

      const peekCard = cards[defaultVisibleCount];
      if (!peekCard) {
        shell.style.maxHeight = "";
        return;
      }

      const gridRect = grid.getBoundingClientRect();
      const peekRect = peekCard.getBoundingClientRect();
      const collapsedHeight = Math.max(0, peekRect.top - gridRect.top + peekRect.height * peekFraction);
      shell.style.maxHeight = `${collapsedHeight}px`;
    };

    const setExpanded = (nextExpanded) => {
      isExpanded = nextExpanded;
      scheduleUpdate();
    };

    button?.addEventListener("click", () => {
      isExpanded = !isExpanded;
      scheduleUpdate();
      if (!isExpanded) {
        root.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    });

    root.addEventListener("more-work:set-expanded", (event) => {
      setExpanded(Boolean(event.detail?.expanded));
    });

    root.addEventListener("more-work:toggle", () => {
      setExpanded(!isExpanded);
    });

    const resizeObserver =
      typeof ResizeObserver !== "undefined" ? new ResizeObserver(() => scheduleUpdate()) : null;

    resizeObserver?.observe(grid);

    images.forEach((image) => {
      if (image.complete) {
        if (typeof image.decode === "function") {
          image.decode().catch(() => {}).finally(scheduleUpdate);
        } else {
          scheduleUpdate();
        }
        return;
      }

      image.addEventListener("load", scheduleUpdate, { once: true });
      image.addEventListener("error", scheduleUpdate, { once: true });
    });

    if (document.fonts?.ready) {
      document.fonts.ready.then(scheduleUpdate).catch(() => {});
    }

    window.addEventListener("resize", scheduleUpdate);
    window.addEventListener("load", scheduleUpdate);
    scheduleUpdate();
  });
</script>

<style>
  .homepage-more-work-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding-bottom: 22px;
  }

  .homepage-more-work-wrap.is-compact {
    max-width: none;
    padding-bottom: 0;
  }

  .homepage-more-work-shell {
    position: relative;
    overflow: visible;
    transition: max-height 0.35s ease;
  }

  .homepage-more-work-shell.is-collapsed,
  .homepage-more-work-shell.is-expanded {
    overflow: hidden;
  }

  .homepage-more-work-shell.is-collapsed .homepage-more-work-fade {
    opacity: 1;
  }

  .homepage-more-work-shell.is-expanded .homepage-more-work-fade {
    opacity: 0;
  }

  .homepage-more-work-fade {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 220px;
    background: linear-gradient(
      180deg,
      rgba(var(--surface-0-rgb), 0) 0%,
      rgba(var(--surface-0-rgb), 0.12) 26%,
      rgba(var(--surface-0-rgb), 0.38) 48%,
      rgba(var(--surface-0-rgb), 0.72) 68%,
      rgba(var(--surface-0-rgb), 0.92) 84%,
      rgba(var(--surface-0-rgb), 1) 100%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 2;
  }

  .homepage-more-work-wrap[data-more-work-group="vote-counts"] .homepage-more-work-fade {
    height: 220px;
  }

  .homepage-more-work {
    padding: 0 22px 10px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 18px;
    row-gap: 28px;
  }

  .homepage-more-work-wrap.is-compact .homepage-more-work {
    padding: 0 22px 10px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .homepage-more-work-wrap.is-compact .homepage-more-work-card {
    height: 100%;
  }

  .homepage-more-work-wrap.is-compact .homepage-more-work-card-inner {
    height: 100%;
    min-height: 100%;
  }

  .homepage-more-work-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .homepage-more-work-card-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(15, 21, 32, 0.08);
    border-radius: 16px;
    background: var(--surface-1);
    box-shadow: 0 10px 26px rgba(15, 21, 32, 0.12), 0 2px 6px rgba(15, 21, 32, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .graphics-grid-actions {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .homepage-more-work-media {
    position: relative;
    overflow: hidden;
    background: var(--surface-2);
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid rgba(15, 21, 32, 0.08);
  }

  .homepage-more-work-image,
  .homepage-more-work-placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  .homepage-more-work-image {
    object-fit: cover;
    transition: transform 0.45s ease, filter 0.35s ease;
  }

  .homepage-more-work-placeholder {
    display: grid;
    place-items: center;
    padding: 20px;
    background: linear-gradient(180deg, var(--surface-1), var(--surface-2));
    color: var(--placeholder-text);
    font-family: "Inter", sans-serif;
    text-align: center;
  }

  .homepage-more-work-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 12px;
    min-height: 196px;
    height: 196px;
    padding: 20px 18px 22px;
    background: var(--surface-1);
  }

  .homepage-more-work-title-wrap {
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .homepage-more-work-wrap.is-compact .homepage-more-work-copy {
    min-height: 224px;
    height: 224px;
    justify-content: flex-start;
  }

  .homepage-more-work-title {
    margin: 0;
    font-family: "Miller Headline", "MillerHeadline", "Merriweather", Georgia, "Times New Roman", serif;
    font-size: clamp(1.22rem, 1.65vw, 1.58rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1.34;
    color: var(--text-heading);
    text-align: center;
    text-wrap: balance;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
    overflow: hidden;
  }

  .homepage-more-work-date {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.3;
    color: #adadad;
    text-align: center;
    margin-top: auto;
    flex: 0 0 auto;
  }

  .homepage-more-work-card:hover,
  .homepage-more-work-card:focus-visible {
    text-decoration: none;
  }

  .homepage-more-work-card:hover .homepage-more-work-card-inner,
  .homepage-more-work-card:focus-visible .homepage-more-work-card-inner {
    transform: translateY(-4px);
    border-color: rgba(var(--theme-accent-rgb), 0.22);
    box-shadow: 0 16px 34px rgba(15, 21, 32, 0.14), 0 4px 10px rgba(15, 21, 32, 0.08);
  }

  .homepage-more-work-card:hover .homepage-more-work-image,
  .homepage-more-work-card:focus-visible .homepage-more-work-image {
    transform: scale(1.045);
  }

  @media (max-width: 980px) {
    .homepage-more-work {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .homepage-more-work-fade {
      height: 180px;
    }

    .homepage-more-work-wrap[data-more-work-group="vote-counts"] .homepage-more-work-fade {
      height: 180px;
    }

    .homepage-more-work {
      padding: 0 16px 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .homepage-more-work-wrap.is-compact .homepage-more-work {
      padding: 0 16px 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .homepage-more-work-wrap.is-compact .homepage-more-work-copy {
      min-height: 208px;
      height: 208px;
    }

    .homepage-more-work-copy {
      gap: 10px;
      min-height: 180px;
      height: 180px;
      padding: 18px 16px 20px;
    }

    .homepage-more-work-title {
      font-size: clamp(1.08rem, 3.15vw, 1.3rem);
    }

    .homepage-more-work-date {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
    }
  }

  @media (max-width: 480px) {
    .homepage-more-work {
      grid-template-columns: 1fr;
    }

    .homepage-more-work-wrap.is-compact .homepage-more-work {
      grid-template-columns: 1fr;
    }
  }
</style>
