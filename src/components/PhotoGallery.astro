---
const { photos = [] } = Astro.props;
---
<div class="photo-gallery-wrap" data-photo-gallery-wrap>
  <section class="photo-gallery-shell is-collapsed" data-photo-gallery-shell>
    <div class="photo-gallery-fade" aria-hidden="true"></div>
    <section class="photo-gallery" aria-label="Photography gallery" data-photo-gallery>
      {photos.map((photo) => (
        <figure class="photo-tile">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </figure>
      ))}
    </section>
  </section>
  <div class="graphics-grid-actions">
    <button class="graphics-show-more site-action-button" type="button" data-photo-show-more hidden>Show More</button>
  </div>
</div>

<script>
  const root = document.querySelector("[data-photo-gallery-wrap]");
  if (root) {
    const shell = root.querySelector("[data-photo-gallery-shell]");
    const gallery = root.querySelector("[data-photo-gallery]");
    const tiles = Array.from(root.querySelectorAll(".photo-tile"));
    const images = Array.from(root.querySelectorAll(".photo-tile img"));
    const button = root.querySelector("[data-photo-show-more]");
    const defaultVisibleCount = 6;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let isExpanded = false;
    let updateFrame = 0;
    let revealObserver = null;
    const revealedTiles = new Set();

    const scheduleUpdate = () => {
      if (updateFrame) window.cancelAnimationFrame(updateFrame);
      updateFrame = window.requestAnimationFrame(() => {
        updateFrame = window.requestAnimationFrame(() => {
          updateCollapsedState();
          updateRevealState();
        });
      });
    };

    const clearRevealObserver = () => {
      if (revealObserver) {
        revealObserver.disconnect();
        revealObserver = null;
      }
    };

    const revealTile = (tile, index) => {
      if (!tile) return;
      revealedTiles.add(index);
      tile.classList.add("is-photo-visible");
    };

    const updateRevealState = () => {
      clearRevealObserver();

      if (!tiles.length) return;

      tiles.forEach((tile, index) => {
        tile.style.setProperty("--photo-reveal-delay", `${(index % 6) * 42}ms`);

        if (revealedTiles.has(index)) {
          tile.classList.add("is-photo-visible");
          return;
        }

        tile.classList.remove("is-photo-visible");
      });

      if (prefersReducedMotion || typeof IntersectionObserver === "undefined") {
        tiles.forEach((tile, index) => revealTile(tile, index));
        return;
      }

      revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const index = Number(entry.target.dataset.photoRevealIndex || "-1");
            if (index < 0) return;

            revealTile(entry.target, index);
            revealObserver?.unobserve(entry.target);
          });
        },
        {
          root: null,
          threshold: 0.16,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      tiles.forEach((tile, index) => {
        tile.dataset.photoRevealIndex = String(index);

        if (revealedTiles.has(index)) return;

        if (tile.getBoundingClientRect().top < window.innerHeight * 0.94) {
          revealTile(tile, index);
          return;
        }

        revealObserver.observe(tile);
      });
    };

    const updateCollapsedState = () => {
      if (!shell || !gallery || !button) return;

      if (tiles.length <= defaultVisibleCount) {
        shell.style.maxHeight = "";
        shell.classList.remove("is-collapsed", "is-expanded");
        button.hidden = true;
        return;
      }

      button.hidden = false;
      button.textContent = isExpanded ? "Show Less" : "Show More";
      shell.classList.toggle("is-collapsed", !isExpanded);
      shell.classList.toggle("is-expanded", isExpanded);

      if (isExpanded) {
        shell.style.maxHeight = `${gallery.scrollHeight}px`;
        return;
      }

      const peekTile = tiles[defaultVisibleCount];
      if (!peekTile) {
        shell.style.maxHeight = "";
        return;
      }

      const galleryRect = gallery.getBoundingClientRect();
      const peekRect = peekTile.getBoundingClientRect();
      const collapsedHeight = Math.max(0, peekRect.top - galleryRect.top + peekRect.height * 0.98);
      shell.style.maxHeight = `${collapsedHeight}px`;
    };

    button?.addEventListener("click", () => {
      isExpanded = !isExpanded;
      scheduleUpdate();
      if (!isExpanded) {
        root.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    });

    const resizeObserver =
      typeof ResizeObserver !== "undefined" ? new ResizeObserver(() => scheduleUpdate()) : null;

    resizeObserver?.observe(gallery);

    images.forEach((image) => {
      if (image.complete) {
        if (typeof image.decode === "function") {
          image.decode().catch(() => {}).finally(scheduleUpdate);
        } else {
          scheduleUpdate();
        }
        return;
      }

      image.addEventListener("load", scheduleUpdate, { once: true });
      image.addEventListener("error", scheduleUpdate, { once: true });
    });

    if (document.fonts?.ready) {
      document.fonts.ready.then(scheduleUpdate).catch(() => {});
    }

    window.addEventListener("resize", scheduleUpdate);
    window.addEventListener("load", scheduleUpdate);
    scheduleUpdate();
  }
</script>

<style>
  .photo-gallery-wrap {
    max-width: 1180px;
    margin: 0 auto;
  }

  .photo-gallery-shell {
    position: relative;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .photo-gallery-shell.is-collapsed .photo-gallery-fade {
    opacity: 1;
  }

  .photo-gallery-shell.is-expanded .photo-gallery-fade {
    opacity: 0;
  }

  .photo-gallery-fade {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 220px;
    background: linear-gradient(
      180deg,
      rgba(var(--surface-0-rgb), 0) 0%,
      rgba(var(--surface-0-rgb), 0.18) 18%,
      rgba(var(--surface-0-rgb), 0.48) 38%,
      rgba(var(--surface-0-rgb), 0.78) 58%,
      rgba(var(--surface-0-rgb), 0.94) 76%,
      rgba(var(--surface-0-rgb), 1) 100%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 1;
  }

  .photo-gallery {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 22px 0;
    column-count: 3;
    column-gap: 10px;
  }

  .photo-tile {
    margin: 0 0 10px;
    overflow: hidden;
    background: var(--surface-2);
    break-inside: avoid;
    line-height: 0;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 520ms ease,
      transform 520ms cubic-bezier(0.2, 0.8, 0.2, 1);
    transition-delay: var(--photo-reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .photo-tile.is-photo-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-tile img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: none;
    object-fit: initial;
    aspect-ratio: auto;
    transition: opacity 0.2s ease;
  }

  .photo-tile:hover img {
    opacity: 0.95;
  }

  .graphics-grid-actions {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  @media (max-width: 1100px) {
    .photo-gallery {
      column-count: 2;
    }
  }

  @media (max-width: 700px) {
    .photo-gallery-fade {
      height: 180px;
    }

    .photo-gallery {
      column-count: 1;
      padding: 0 16px 0;
      column-gap: 10px;
    }

    .photo-tile {
      margin-bottom: 10px;
    }
  }
</style>
