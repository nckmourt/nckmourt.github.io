---
const { projects = [] } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

function formatDisplayDate(dateText) {
  const parsed = new Date(dateText);
  return Number.isNaN(parsed.getTime()) ? dateText : dateFormatter.format(parsed);
}
---
<div class="homepage-featured">
  {projects.map((project) => {
    const href = project.data.externalUrl || `/projects/${project.slug}/`;
    const target = project.data.externalUrl ? "_blank" : "_self";

    return (
      <a
        class="homepage-featured-row"
        href={href}
        target={target}
        rel={project.data.externalUrl ? "noopener noreferrer" : ""}
        aria-label={project.data.title}
      >
        <div class="homepage-featured-media">
          {project.data.heroImage ? (
            <img
              class="homepage-featured-image"
              src={project.data.heroImage}
              alt={project.data.title}
              loading="lazy"
            />
          ) : (
            <div class="homepage-featured-placeholder">{project.data.title}</div>
          )}
        </div>

        <div class="homepage-featured-copy">
          <div class="homepage-featured-meta">
            <span>{formatDisplayDate(project.data.date)}</span>
            {project.data.tags?.[0] && <span>{project.data.tags[0].replace(/-/g, " ")}</span>}
          </div>
          <h3 class="homepage-featured-title">{project.data.title}</h3>
          <p class="homepage-featured-description">{project.data.description}</p>
        </div>
      </a>
    );
  })}
</div>

<style>
  .homepage-featured {
    width: min(100%, 1180px);
    margin: 0 auto;
    display: grid;
    gap: clamp(42px, 7vw, 92px);
    padding: 0 22px;
  }

  .homepage-featured-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  .homepage-featured-row:nth-child(even) {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .homepage-featured-row:nth-child(even) .homepage-featured-media {
    order: 2;
  }

  .homepage-featured-row:nth-child(even) .homepage-featured-copy {
    order: 1;
  }

  .homepage-featured-media {
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--surface-2);
    aspect-ratio: 16 / 10;
  }

  .homepage-featured-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease, filter 0.3s ease;
  }

  .homepage-featured-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 24px;
    background: var(--placeholder-bg);
    color: var(--placeholder-text);
    font-family: "Literata", Georgia, "Times New Roman", serif;
    text-align: center;
  }

  .homepage-featured-copy {
    max-width: none;
    width: 100%;
  }

  .homepage-featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    margin-bottom: 16px;
    color: var(--text-muted);
    font-family: "Inter", sans-serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .homepage-featured-title {
    margin: 0 0 14px;
    font-family: "Literata", Georgia, "Times New Roman", serif;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    line-height: 1.14;
    color: var(--text-heading);
    transition: color 0.2s ease;
  }

  .homepage-featured-description {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-soft);
  }

  .homepage-featured-row:hover,
  .homepage-featured-row:focus-visible {
    text-decoration: none;
  }

  .homepage-featured-row:hover .homepage-featured-image,
  .homepage-featured-row:focus-visible .homepage-featured-image {
    transform: scale(1.035);
    filter: brightness(0.92);
  }

  .homepage-featured-row:hover .homepage-featured-title,
  .homepage-featured-row:focus-visible .homepage-featured-title {
    color: var(--link);
  }

  @media (max-width: 900px) {
    .homepage-featured-row,
    .homepage-featured-row:nth-child(even) {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .homepage-featured-row:nth-child(even) .homepage-featured-media,
    .homepage-featured-row:nth-child(even) .homepage-featured-copy {
      order: initial;
    }

    .homepage-featured-copy {
      max-width: 100%;
    }
  }

  @media (max-width: 700px) {
    .homepage-featured {
      padding: 0 16px;
    }
  }
</style>
