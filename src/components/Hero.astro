---
const heroSlides = [
  // Tweak these to adjust focal points.
  { src: "/images/hero/capitol.jpg", positionY: "22%", mobilePositionY: "52%", zoom: 1.0 },
  { src: "/images/hero/foggy_bottom.jpg", positionY: "0%", mobilePositionY: "48%", zoom: 1 },
  { src: "/images/hero/scotus.jpg", positionY: "44%", mobilePositionY: "44%", zoom: 1 },
];
---
<section class="hero-home" aria-label="Homepage introduction">
  <div class="hero-carousel" data-hero-carousel>
    <div class="hero-slides" aria-hidden="true">
      {heroSlides.map((slide, index) => (
        <div
          class:list={["hero-slide", index === 0 && "is-active"]}
          style={`--hero-slide-position-y:${slide.positionY}; --hero-slide-mobile-position-y:${slide.mobilePositionY}; --hero-slide-zoom:${slide.zoom ?? 1.08};`}
        >
          <img class="hero-slide-bg" src={slide.src} alt="" loading={index === 0 ? "eager" : "lazy"} />
          <div class="hero-slide-main-wrap">
            <img class="hero-slide-main" src={slide.src} alt="" loading={index === 0 ? "eager" : "lazy"} />
          </div>
        </div>
      ))}
    </div>

    <div class="hero-overlay">
      <h1 class="hero-name">Nick Mourtoupalas</h1>
      <p class="hero-bio">
        I transform data into visual reporting and interactive tools that reveal how power and policy shape the world around us.
      </p>
    </div>
  </div>
</section>

<script>
  const carouselEl = document.querySelector("[data-hero-carousel]");
  if (carouselEl) {
    const slides = Array.from(carouselEl.querySelectorAll(".hero-slide"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let currentIndex = 0;

    if (slides.length > 1 && !reduceMotion) {
      window.setInterval(() => {
        slides[currentIndex].classList.remove("is-active");
        currentIndex = (currentIndex + 1) % slides.length;
        slides[currentIndex].classList.add("is-active");
      }, 5000);
    }
  }
</script>

<style>
  .hero-home {
    width: 100%;
    background: var(--surface-0);
  }

  .hero-carousel {
    position: relative;
    width: 100%;
    height: min(68vw, 750px);
    min-height: 460px;
    overflow: hidden;
    background: var(--surface-2);
  }

  .hero-slides {
    position: absolute;
    inset: 0;
  }

  .hero-slides::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 36%, rgba(9, 14, 24, 0.12), rgba(9, 14, 24, 0.42) 72%),
      linear-gradient(180deg, rgba(9, 14, 24, 0.12), rgba(9, 14, 24, 0.38));
    pointer-events: none;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1200ms ease-in-out;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-slide-bg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% var(--hero-slide-position-y, 50%);
    filter: blur(28px) brightness(0.78) saturate(0.88);
    transform: scale(1.14);
  }

  .hero-slide-main-wrap {
    position: absolute;
    top: clamp(16px, 2.2vw, 30px);
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(1356px, calc(100vw - 44px));
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }

  .hero-slide-main {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% var(--hero-slide-position-y, 50%);
    transform: scale(var(--hero-slide-zoom, 1.08));
    transform-origin: center center;
    filter: brightness(0.96) saturate(0.94) drop-shadow(0 20px 26px rgba(0, 0, 0, 0.28));
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.04) 8%, rgba(0, 0, 0, 0.12) 14%, rgba(0, 0, 0, 0.24) 20%, rgba(0, 0, 0, 0.42) 26%, rgba(0, 0, 0, 0.68) 32%, rgba(0, 0, 0, 0.9) 38%, #000 44%, #000 56%, rgba(0, 0, 0, 0.9) 62%, rgba(0, 0, 0, 0.68) 68%, rgba(0, 0, 0, 0.42) 74%, rgba(0, 0, 0, 0.24) 80%, rgba(0, 0, 0, 0.12) 86%, rgba(0, 0, 0, 0.04) 92%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.04) 8%, rgba(0, 0, 0, 0.12) 14%, rgba(0, 0, 0, 0.24) 20%, rgba(0, 0, 0, 0.42) 26%, rgba(0, 0, 0, 0.68) 32%, rgba(0, 0, 0, 0.9) 38%, #000 44%, #000 56%, rgba(0, 0, 0, 0.9) 62%, rgba(0, 0, 0, 0.68) 68%, rgba(0, 0, 0, 0.42) 74%, rgba(0, 0, 0, 0.24) 80%, rgba(0, 0, 0, 0.12) 86%, rgba(0, 0, 0, 0.04) 92%, transparent 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    padding: 0 var(--page-gutter);
    text-align: center;
  }

  .hero-name {
    position: absolute;
    top: 50%;
    left: 50%;
    margin: 0;
    width: fit-content;
    max-width: calc(100% - (var(--page-gutter) * 2));
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #f3f6fb;
    line-height: 0.95;
    text-align: center;
    white-space: nowrap;
    transform: translate(-50%, -50%) translateY(20px);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }

  .hero-bio {
    position: absolute;
    top: 50%;
    left: 50%;
    margin: 0;
    width: min(500px, calc(100% - (var(--page-gutter) * 2)));
    max-width: 500px;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(243, 246, 251, 0.92);
    text-align: center;
    transform: translate(-50%, -50%) translateY(112px);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 900px) {
    .hero-name {
      font-size: clamp(1.55rem, 7vw, 2.6rem);
    }

    .hero-bio {
      font-size: 15px;
      line-height: 1.6;
      transform: translate(-50%, -50%) translateY(78px);
    }
  }

  @media (max-width: 600px) {
    .hero-carousel {
      min-height: 360px;
      height: min(88vw, 560px);
    }

    .hero-slide-main-wrap {
      top: 0;
      bottom: 0;
      width: 100%;
    }

    .hero-slide-bg,
    .hero-slide-main {
      object-position: 50% var(--hero-slide-mobile-position-y, var(--hero-slide-position-y, 50%));
    }

    .hero-slide-main {
      height: 100%;
      object-fit: cover;
      transform: none;
      -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.06) 10%, rgba(0, 0, 0, 0.18) 18%, rgba(0, 0, 0, 0.42) 26%, rgba(0, 0, 0, 0.78) 34%, #000 42%, #000 58%, rgba(0, 0, 0, 0.78) 66%, rgba(0, 0, 0, 0.42) 74%, rgba(0, 0, 0, 0.18) 82%, rgba(0, 0, 0, 0.06) 90%, transparent 100%);
      mask-image: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.06) 10%, rgba(0, 0, 0, 0.18) 18%, rgba(0, 0, 0, 0.42) 26%, rgba(0, 0, 0, 0.78) 34%, #000 42%, #000 58%, rgba(0, 0, 0, 0.78) 66%, rgba(0, 0, 0, 0.42) 74%, rgba(0, 0, 0, 0.18) 82%, rgba(0, 0, 0, 0.06) 90%, transparent 100%);
    }

    .hero-name {
      font-size: clamp(1.15rem, 6.1vw, 2rem);
      letter-spacing: 0.04em;
    }

    .hero-bio {
      width: min(420px, calc(100% - (var(--page-gutter) * 2)));
      transform: translate(-50%, -50%) translateY(72px);
    }

  }
</style>
