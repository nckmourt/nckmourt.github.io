---
const heroSlides = [
  // Tweak these to adjust focal points.
  { src: "/images/hero/capitol.jpg", positionY: "35%", mobilePositionY: "35%", zoom: 1 },
  { src: "/images/hero/foggy_bottom.jpg", positionY: "25%", mobilePositionY: "30%", zoom: 1 },
  { src: "/images/hero/scotus.jpg", positionY: "50%", mobilePositionY: "50%", zoom: 1 },
];
---
<section class="hero-home" aria-label="Homepage introduction">
  <div class="hero-carousel" data-hero-carousel>
    <div class="hero-slides" aria-hidden="true">
      {heroSlides.map((slide, index) => (
        <div
          class:list={["hero-slide", index === 0 && "is-active"]}
          style={`--hero-slide-position-y:${slide.positionY}; --hero-slide-mobile-position-y:${slide.mobilePositionY}; --hero-slide-zoom:${slide.zoom ?? 1.08};`}
        >
          <img class="hero-slide-bg" src={slide.src} alt="" loading={index === 0 ? "eager" : "lazy"} />
          <div class="hero-slide-main-wrap">
            <img class="hero-slide-main" src={slide.src} alt="" loading={index === 0 ? "eager" : "lazy"} />
          </div>
        </div>
      ))}
    </div>

    <div class="hero-overlay">
      <div class="hero-copy">
        <h1 class="hero-name">Nick Mourtoupalas</h1>
      </div>
    </div>
  </div>
</section>

<script>
  const carouselEl = document.querySelector("[data-hero-carousel]");
  if (carouselEl) {
    const slides = Array.from(carouselEl.querySelectorAll(".hero-slide"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let currentIndex = 0;

    if (slides.length > 1 && !reduceMotion) {
      window.setInterval(() => {
        slides[currentIndex].classList.remove("is-active");
        currentIndex = (currentIndex + 1) % slides.length;
        slides[currentIndex].classList.add("is-active");
      }, 5000);
    }
  }
</script>

<style>
  .hero-home {
    width: 100%;
    background: var(--surface-0);
  }

  .hero-carousel {
    --hero-fluid: clamp(0, calc((100vw - 420px) / 480px), 1);
    --hero-side-gap: clamp(0px, calc((100vw - 420px) * 0.1), 44px);
    position: relative;
    width: 100%;
    height: clamp(360px, 68vw, 500px);
    overflow: hidden;
    background: var(--surface-2);
  }

  .hero-slides {
    position: absolute;
    inset: 0;
  }

  .hero-slides::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 36%, var(--hero-overlay-radial-start), var(--hero-overlay-radial-end) 72%),
      linear-gradient(180deg, var(--hero-overlay-linear-start), var(--hero-overlay-linear-end));
    pointer-events: none;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1200ms ease-in-out;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-slide-bg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% var(--hero-slide-position-y, 50%);
    filter:
      blur(calc(10px + (18px * var(--hero-fluid))))
      brightness(calc(0.9 - (0.12 * var(--hero-fluid))))
      saturate(calc(0.94 - (0.06 * var(--hero-fluid))));
    transform: scale(calc(1 + (0.14 * var(--hero-fluid))));
    opacity: clamp(0.28, var(--hero-fluid), 1);
    transition: opacity 0.35s ease, filter 0.35s ease, transform 0.35s ease;
  }

  .hero-slide-main-wrap {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(1356px, calc(100vw - var(--hero-side-gap)));
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }

  .hero-slide-main {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% var(--hero-slide-position-y, 50%);
    transform: scale(var(--hero-slide-zoom, 1.08));
    transform-origin: center center;
    filter: brightness(0.96) saturate(0.94) drop-shadow(0 20px 26px rgba(0, 0, 0, 0.28));
    -webkit-mask-image: linear-gradient(
      90deg,
      rgba(0, 0, 0, calc(1 - var(--hero-fluid))) 0%,
      rgba(0, 0, 0, calc(1 - (0.96 * var(--hero-fluid)))) 8%,
      rgba(0, 0, 0, calc(1 - (0.88 * var(--hero-fluid)))) 14%,
      rgba(0, 0, 0, calc(1 - (0.76 * var(--hero-fluid)))) 20%,
      rgba(0, 0, 0, calc(1 - (0.58 * var(--hero-fluid)))) 26%,
      rgba(0, 0, 0, calc(1 - (0.32 * var(--hero-fluid)))) 32%,
      rgba(0, 0, 0, calc(1 - (0.1 * var(--hero-fluid)))) 38%,
      #000 44%,
      #000 56%,
      rgba(0, 0, 0, calc(1 - (0.1 * var(--hero-fluid)))) 62%,
      rgba(0, 0, 0, calc(1 - (0.32 * var(--hero-fluid)))) 68%,
      rgba(0, 0, 0, calc(1 - (0.58 * var(--hero-fluid)))) 74%,
      rgba(0, 0, 0, calc(1 - (0.76 * var(--hero-fluid)))) 80%,
      rgba(0, 0, 0, calc(1 - (0.88 * var(--hero-fluid)))) 86%,
      rgba(0, 0, 0, calc(1 - (0.96 * var(--hero-fluid)))) 92%,
      rgba(0, 0, 0, calc(1 - var(--hero-fluid))) 100%
    );
    mask-image: linear-gradient(
      90deg,
      rgba(0, 0, 0, calc(1 - var(--hero-fluid))) 0%,
      rgba(0, 0, 0, calc(1 - (0.96 * var(--hero-fluid)))) 8%,
      rgba(0, 0, 0, calc(1 - (0.88 * var(--hero-fluid)))) 14%,
      rgba(0, 0, 0, calc(1 - (0.76 * var(--hero-fluid)))) 20%,
      rgba(0, 0, 0, calc(1 - (0.58 * var(--hero-fluid)))) 26%,
      rgba(0, 0, 0, calc(1 - (0.32 * var(--hero-fluid)))) 32%,
      rgba(0, 0, 0, calc(1 - (0.1 * var(--hero-fluid)))) 38%,
      #000 44%,
      #000 56%,
      rgba(0, 0, 0, calc(1 - (0.1 * var(--hero-fluid)))) 62%,
      rgba(0, 0, 0, calc(1 - (0.32 * var(--hero-fluid)))) 68%,
      rgba(0, 0, 0, calc(1 - (0.58 * var(--hero-fluid)))) 74%,
      rgba(0, 0, 0, calc(1 - (0.76 * var(--hero-fluid)))) 80%,
      rgba(0, 0, 0, calc(1 - (0.88 * var(--hero-fluid)))) 86%,
      rgba(0, 0, 0, calc(1 - (0.96 * var(--hero-fluid)))) 92%,
      rgba(0, 0, 0, calc(1 - var(--hero-fluid))) 100%
    );
    transition: -webkit-mask-image 0.35s ease, mask-image 0.35s ease, filter 0.35s ease;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
    place-items: center;
    padding: 0 var(--page-gutter);
    text-align: center;
  }

  .hero-copy {
    width: min(750px, calc(100% - (var(--page-gutter) * 2)));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transform: translateY(20px);
  }

  .hero-name {
    margin: 0;
    width: fit-content;
    max-width: none;
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: clamp(1.45rem, 7.8vw, 6.35rem);
    letter-spacing: clamp(0.04em, 0.046em + 0.02vw, 0.055em);
    text-transform: uppercase;
    color: var(--hero-title);
    line-height: 0.95;
    text-align: center;
    white-space: nowrap;
    text-shadow: var(--hero-title-shadow);
  }

  .hero-slide-bg,
  .hero-slide-main {
    object-position: 50% var(--hero-slide-mobile-position-y, var(--hero-slide-position-y, 50%));
  }
</style>
